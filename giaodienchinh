        // ==================== ALERTS ====================
        function renderAlerts() {
            const container = document.getElementById('alertsContainer');
            const activeAlerts = appData.alerts.filter(a => !a.dismissed);

            if (activeAlerts.length === 0) {
                container.innerHTML = '<p class="text-gray-400 text-sm italic">Không có cảnh báo nào 🎉</p>';
                return;
            }

            container.innerHTML = activeAlerts.map(alert => `
                <div class="alert-card alert-${alert.severity} animate-slide-in">
                    <i class="fas fa-${alert.severity === 'danger' ? 'exclamation-circle text-red-500' : alert.severity === 'warning' ? 'exclamation-triangle text-amber-500' : 'info-circle text-blue-500'}"></i>
                    <div class="flex-1">
                        <p class="text-sm font-medium text-gray-900">${alert.message}</p>
                    </div>
                    <button class="text-gray-400 hover:text-gray-600" onclick="dismissAlert(${alert.id})">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            `).join('');

            document.getElementById('notifBadge').textContent = activeAlerts.length;
        }

        function dismissAlert(id) {
            const alert = appData.alerts.find(a => a.id === id);
            if (alert) alert.dismissed = true;
            renderAlerts();
            showToast('Đã đánh dấu đã đọc');
        }

        function dismissAllAlerts() {
            appData.alerts.forEach(a => a.dismissed = true);
