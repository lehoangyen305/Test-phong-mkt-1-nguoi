                <div class="p-4 rounded-lg border border-gray-200 bg-white hover:shadow-sm transition">
                    <div class="flex items-start gap-3">
                        <div class="expense-category-icon ${meta.color}">${meta.icon}</div>
                        <div class="flex-1">
                            <div class="flex items-center justify-between">
                                <h4 class="font-medium text-gray-900">${meta.label}</h4>
                                <span class="font-bold text-gray-900">$${exp.amount}</span>
                            </div>
                            <p class="text-sm text-gray-600 mt-1">${exp.description}</p>
                            ${exp.person ? `<p class="text-xs text-gray-400 mt-1"><i class="fas fa-user mr-1"></i>${exp.person}</p>` : ''}
                            <p class="text-xs text-gray-400 mt-1">${exp.date}</p>
                        </div>
                    </div>
                </div>
                `;
            }).join('');
        }

        function openAddExpenseModal() {
            document.getElementById('addExpenseModal').classList.add('active');
        }

        function addExpense() {
            const category = document.getElementById('expenseCategory').value;
            const amount = parseFloat(document.getElementById('expenseAmount').value);
            const description = document.getElementById('expenseDesc').value;
            const person = document.getElementById('expensePerson').value;

            if (!amount || !description) return;

            appData.expenses.push({
                id: Date.now(),
                category,
                amount,
                description,
                date: new Date().toISOString().split('T')[0],
                approved: true,
                person
            });

            closeModal('addExpenseModal');
            renderExpenses();
            showToast('Đã thêm chi phí');
        }

        // ==================== APPROVALS ====================
        function renderApprovals() {
            const container = document.getElementById('approvalList');
            container.innerHTML = appData.approvals.map(app => `
                <div class="p-4 rounded-lg border ${app.status === 'approved' ? 'border-green-200 bg-green-50' : 'border-amber-200 bg-amber-50'}">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <div class="flex items-center gap-2">
                                <h4 class="font-semibold text-gray-900">${app.reason}</h4>
                                <span class="badge badge-${app.status === 'approved' ? 'green' : 'amber'} text-xs">${app.status === 'approved' ? 'Đã duyệt' : 'Chờ duyệt'}</span>
                            </div>
                            <p class="text-sm text-gray-600 mt-1">Số tiền: <span class="font-bold">$${app.amount.toLocaleString()}</span></p>
                            <p class="text-xs text-gray-400 mt-1">Ngày gửi: ${app.date}</p>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function openApprovalModal() {
            document.getElementById('approvalModal').classList.add('active');
        }

        function submitApproval() {
            const category = document.getElementById('approvalCategory').value;
            const amount = parseFloat(document.getElementById('approvalAmount').value);
            const reason = document.getElementById('approvalReason').value;

            if (!amount || !reason) return;

            appData.approvals.push({
                id: Date.now(),
                category,
                amount,
                reason,
                status: 'pending',
                date: new Date().toISOString().split('T')[0]
            });

            closeModal('approvalModal');
            renderApprovals();
            showToast('Đã gửi đơn xin duyệt');
        }

        // ==================== PLAN ====================
        function renderPlan() {
            const plan = appData.plans[currentPlanMonth];
            const container = document.getElementById('planContent');
            const completed = plan.checklist.filter(c => c.done).length;
            const total = plan.checklist.length;
            const pct = Math.round(completed / total * 100);

            container.innerHTML = `
                <div class="mb-6">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="text-xl font-bold text-gray-900">${plan.month}: ${plan.title}</h3>
                        <span class="badge badge-blue text-sm">${completed}/${total} hoàn thành</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill bg-blue-500" style="width: ${pct}%"></div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <div class="bg-blue-50 p-4 rounded-lg text-center">
                        <p class="text-2xl font-bold text-blue-600">$${plan.budget.toLocaleString()}</p>
                        <p class="text-sm text-gray-600">Ngân sách dự kiến</p>
                    </div>
                    <div class="bg-green-50 p-4 rounded-lg text-center">
                        <p class="text-2xl font-bold text-green-600">${plan.kpi.leads}</p>
                        <p class="text-sm text-gray-600">KPI Leads</p>
                    </div>
                    <div class="bg-purple-50 p-4 rounded-lg text-center">
                        <p class="text-2xl font-bold text-purple-600">${plan.kpi.roas}x</p>
                        <p class="text-sm text-gray-600">Target ROAS</p>
                    </div>
                </div>

                <div class="space-y-3">
                    <h4 class="font-bold text-gray-900">Checklist</h4>
                    ${plan.checklist.map((item, idx) => `
                        <div class="flex items-center gap-3 p-3 rounded-lg border ${item.done ? 'bg-green-50 border-green-200' : 'bg-white border-gray-200'}">
                            <div class="checkbox-custom ${item.done ? 'checked' : ''}" onclick="togglePlanItem(${currentPlanMonth}, ${idx})">
                                ${item.done ? '<i class="fas fa-check text-xs"></i>' : ''}
                            </div>
                            <span class="${item.done ? 'line-through text-gray-400' : 'text-gray-900'}">${item.text}</span>
                        </div>
                    `).join('')}
                </div>
            `;
        }

        function togglePlanItem(month, idx) {
            appData.plans[month].checklist[idx].done = !appData.plans[month].checklist[idx].done;
            renderPlan();
        }

        // ==================== CONTRACTS ====================
        function renderContracts() {
            const container = document.getElementById('contractsList');
            let filtered = appData.contracts;

            if (currentContractFilter === 'overdue') filtered = filtered.filter(c => c.status === 'overdue');
            else if (currentContractFilter === 'pending') filtered = filtered.filter(c => c.status === 'pending');

            container.innerHTML = filtered.map(contract => {
                const daysOverdue = contract.status === 'overdue' ? 
                    Math.ceil((new Date() - new Date(contract.due_date)) / (1000 * 60 * 60 * 24)) : 0;

                return `
                <div class="p-4 rounded-lg border ${contract.status === 'overdue' ? 'border-red-200 bg-red-50' : 'border-gray-200 bg-white'}">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <div class="flex items-center gap-2">
                                <h4 class="font-semibold text-gray-900">${contract.partner}</h4>
                                <span class="badge badge-${contract.type === 'KOL' ? 'purple' : contract.type === 'Agency' ? 'blue' : 'gray'} text-xs">${contract.type}</span>
                                ${contract.status === 'overdue' ? '<span class="badge badge-red text-xs"><i class="fas fa-exclamation-circle mr-1"></i>Quá hạn ' + daysOverdue + ' ngày</span>' : ''}
                            </div>
                            <div class="grid grid-cols-2 gap-4 mt-3 text-sm">
                                <div>
                                    <p class="text-gray-500">Giá trị</p>
                                    <p class="font-bold text-gray-900">$${contract.value.toLocaleString()}</p>
                                </div>
                                <div>
                                    <p class="text-gray-500">Hạn thanh toán</p>
                                    <p class="font-bold ${contract.status === 'overdue' ? 'text-red-600' : 'text-gray-900'}">${contract.due_date}</p>
                                </div>
                                <div>
                                    <p class="text-gray-500">Đã nhắc</p>
                                    <p class="font-bold text-gray-900">${contract.reminders} lần</p>
                                </div>
                                <div>
                                    <p class="text-gray-500">TT chuyển khoản</p>
                                    <p class="text-gray-700">${contract.payment_info}</p>
                                </div>
                            </div>
                            ${contract.notes ? `<p class="text-sm text-amber-600 mt-2"><i class="fas fa-sticky-note mr-1"></i>${contract.notes}</p>` : ''}
                        </div>
                        <div class="flex flex-col gap-2">
                            <button class="btn btn-primary btn-sm" onclick="remindContract(${contract.id})">
                                <i class="fas fa-bell"></i>Nhắc
                            </button>
                            <button class="btn btn-success btn-sm" onclick="payContract(${contract.id})">
                                <i class="fas fa-check"></i>Đã TT
                            </button>
                        </div>
                    </div>
                </div>
                `;
            }).join('');
        }

        function remindContract(id) {
            const contract = appData.contracts.find(c => c.id === id);
            if (contract) {
                contract.reminders++;
                renderContracts();
                showToast(`Đã gửi nhắc thanh toán lần ${contract.reminders} cho ${contract.partner}`);
            }
        }

        function payContract(id) {
            const contract = appData.contracts.find(c => c.id === id);
            if (contract) {
                contract.status = 'paid';
                renderContracts();
                showToast(`Đã đánh dấu thanh toán cho ${contract.partner}`);
            }
        }

        // ==================== REPORT ====================
        function renderReport() {
            document.getElementById('reportChannels').innerHTML = appData.report.channels.map(ch => `
                <tr>
                    <td class="px-4 py-3 font-medium">${ch.name}</td>
                    <td class="px-4 py-3 text-right">$${ch.spend.toLocaleString()}</td>
                    <td class="px-4 py-3 text-right">${ch.leads}</td>
                    <td class="px-4 py-3 text-right font-bold ${ch.roas >= 3 ? 'text-green-600' : 'text-amber-600'}">${ch.roas}x</td>
                    <td class="px-4 py-3 text-right">$${ch.cpl}</td>
                    <td class="px-4 py-3 text-center">
                        <span class="badge badge-${ch.rating === 'Xuất sắc' ? 'green' : ch.rating === 'Tốt' ? 'blue' : 'amber'} text-xs">${ch.rating}</span>
                    </td>
                </tr>
            `).join('');

            document.getElementById('reportGood').innerHTML = appData.report.good.map(item => `
                <li class="flex items-start gap-2 text-sm text-gray-700">
                    <i class="fas fa-check-circle text-green-500 mt-0.5"></i>
                    <span>${item}</span>
                </li>
            `).join('');

            document.getElementById('reportImprove').innerHTML = appData.report.improve.map(item => `
                <li class="flex items-start gap-2 text-sm text-gray-700">
                    <i class="fas fa-exclamation-circle text-amber-500 mt-0.5"></i>
                    <span>${item}</span>
                </li>
            `).join('');

            document.getElementById('reportNextPlan').innerHTML = `<p class="text-sm text-gray-700">${appData.report.nextPlan}</p>`;
        }

        function generatePDF() {
            showToast('Đang tạo PDF... (tính năng demo)');
            setTimeout(() => {
                showToast('PDF đã sẵn sàng để tải xuống!');
            }, 1500);
        }

        function sendReport() {
            showToast('Đã gửi báo cáo đến sếp qua email!');
        }

        // ==================== PROMPTS ====================
        function renderPrompts() {
            const container = document.getElementById('promptsList');
            const search = document.getElementById('promptSearch')?.value?.toLowerCase() || '';

            let filtered = appData.prompts;
            if (currentPromptFilter !== 'all') {
                filtered = filtered.filter(p => p.category === currentPromptFilter);
            }
            if (search) {
                filtered = filtered.filter(p => 
                    p.title.toLowerCase().includes(search) || 
                    p.tags.some(t => t.toLowerCase().includes(search))
                );
            }

            container.innerHTML = filtered.map(prompt => `
                <div class="prompt-card">
                    <button class="copy-btn btn btn-ghost btn-sm" onclick="copyPrompt(${prompt.id})">
                        <i class="fas fa-copy"></i>
                    </button>
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-${prompt.category === 'caption' ? 'blue' : prompt.category === 'ads' ? 'green' : prompt.category === 'video' ? 'purple' : prompt.category === 'email' ? 'amber' : 'gray'} text-xs">
                            ${prompt.category}
                        </span>
                    </div>
                    <h4 class="font-semibold text-gray-900 mb-2">${prompt.title}</h4>
                    <p class="text-sm text-gray-600 line-clamp-3">${prompt.template}</p>
                    <div class="flex gap-1 mt-3 flex-wrap">
                        ${prompt.tags.map(tag => `<span class="text-xs text-gray-400">#${tag}</span>`).join('')}
                    </div>
                </div>
            `).join('');
        }

        function copyPrompt(id) {
            const prompt = appData.prompts.find(p => p.id === id);
            if (prompt) {
                navigator.clipboard.writeText(prompt.template).then(() => {
                    showToast('Đã copy prompt!');
                });
            }
        }

        function openAddPromptModal() {
            document.getElementById('addPromptModal').classList.add('active');
        }

        function addPrompt() {
            const title = document.getElementById('promptTitle').value;
            const category = document.getElementById('promptCategory').value;
            const template = document.getElementById('promptTemplate').value;
            const tags = document.getElementById('promptTags').value.split(',').map(t => t.trim()).filter(t => t);

            if (!title || !template) return;

            appData.prompts.push({
                id: Date.now(),
                title,
                template,
                category,
                tags
            });

            closeModal('addPromptModal');
            renderPrompts();
            showToast('Đã thêm prompt mới');
        }

        // ==================== FILTERS ====================
        function setupFilters() {
            // Message filters
            document.querySelectorAll('[data-filter]').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-filter]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    currentMessageFilter = this.dataset.filter;
                    renderMessages();
                });
            });

            // Plan month filters
            document.querySelectorAll('[data-month]').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-month]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    currentPlanMonth = parseInt(this.dataset.month);
                    renderPlan();
                });
            });

            // Contract filters
            document.querySelectorAll('[data-contract]').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-contract]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    currentContractFilter = this.dataset.contract;
                    renderContracts();
                });
            });

            // Prompt category filters
            document.querySelectorAll('[data-prompt-cat]').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-prompt-cat]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    currentPromptFilter = this.dataset.promptCat;
                    renderPrompts();
                });
            });

            // Prompt search
            document.getElementById('promptSearch')?.addEventListener('input', renderPrompts);
        }

        // ==================== UTILS ====================
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const msg = document.getElementById('toastMessage');
            msg.textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        // Close modals on backdrop click
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) this.classList.remove('active');
            });
        });
    </script>
</body>
</html>
