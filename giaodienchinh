        function exportToCRM() {
            const consultant = document.getElementById('consultantSelect').value;
            if (selectedLeads.size === 0) {
                showToast('Vui lòng chọn ít nhất 1 khách hàng', 'error');
                return;
            }
            if (!consultant) {
                showToast('Vui lòng chọn tư vấn viên', 'error');
                return;
            }

            const selected = appData.leads.filter(l => selectedLeads.has(l.id));
            const exportData = selected.map(lead => ({
                name: lead.name,
                phone: lead.phone,
                email: lead.email,
                need: lead.need,
                source: lead.source,
                consultant: consultant,
                chat_note: lead.chat_note,
                transferred_at: new Date().toISOString().split('T')[0]
            }));

            const jsonStr = JSON.stringify(exportData, null, 2);
            const blob = new Blob([jsonStr], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `leads_export_${new Date().toISOString().split('T')[0]}.json`;
            a.click();
            URL.revokeObjectURL(url);

            // Update leads status
            selected.forEach(lead => {
                lead.status = 'transferred';
                lead.consultant = consultant;
                lead.transferred_at = new Date().toISOString().split('T')[0];
            });

            selectedLeads.clear();
            renderMessages();
            renderSelectedLeads();
            showToast(`Đã export ${exportData.length} leads sang JSON`);
        }

